<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<HBox xmlns:fx="http://javafx.com/fxml" 
      alignment="CENTER_LEFT" spacing="10.0" prefHeight="65.0"
      fx:controller="com.ouhinformation.controllers.admin.AdminController"
      style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
    <padding>
        <Insets top="10.0" right="25.0" bottom="10.0" left="25.0"/>
    </padding>
    <Label text="Admin Dashboard" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #064e3b;"/>
    <Region HBox.hgrow="ALWAYS" />
    <Button text="Logout" fx:id="logoutButton" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20 8 20; -fx-cursor: hand; -fx-font-weight: 700; -fx-background-radius: 6;"/>
</HBox>
