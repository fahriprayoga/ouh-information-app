<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.ouhinformation.controllers.admin.SectionDetailController"
            style="-fx-background-color: #f8fafc;">

    <top>
        <fx:include source="top_bar.fxml" />
    </top>

    <left>
        <fx:include source="sidebar.fxml" />
    </left>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets top="24.0" right="24.0" bottom="24.0" left="24.0"/>
            </padding>

            <!-- Header Action Area -->
            <HBox alignment="CENTER_LEFT" spacing="15.0">
                <Button fx:id="backButton" text="&lt; Kembali ke Daftar" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-size: 14px; -fx-cursor: hand;" />
                <Label fx:id="headerTitle" text="Detail Informasi" style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="previewButton" text="Preview" style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" />
                <Button fx:id="saveButton" text="Simpan Perubahan" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 6; -fx-cursor: hand;" />
            </HBox>

            <HBox spacing="24.0" VBox.vgrow="ALWAYS">
                <!-- Editor Main Area -->
                <VBox spacing="24.0" HBox.hgrow="ALWAYS">
                    <!-- Metadata Form -->
                    <VBox spacing="15.0" style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
                        <VBox spacing="8.0">
                            <Label text="JUDUL INFORMASI" style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: #94a3b8;" />
                            <TextField fx:id="titleField" promptText="Masukkan judul utama..." 
                                       style="-fx-font-size: 16px; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: #f8fafc;" />
                        </VBox>
                        <VBox spacing="8.0">
                            <Label text="DESKRIPSI SINGKAT" style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: #94a3b8;" />
                            <TextField fx:id="descField" promptText="Masukkan deskripsi pendek..." 
                                       style="-fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: #f8fafc;" />
                        </VBox>
                        <VBox spacing="8.0">
                            <Label text="KATEGORI (OPTIONAL)" style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: #94a3b8;" />
                            <javafx.scene.control.ComboBox fx:id="categoryComboBox" promptText="Pilih kategori..." 
                                       style="-fx-font-size: 14px; -fx-padding: 5; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: #f8fafc; -fx-min-width: 300;" />
                        </VBox>
                    </VBox>

                    <!-- Dynamic Components Container -->
                    <VBox spacing="12.0" VBox.vgrow="ALWAYS">
                        <Label text="ISI KONTEN" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569;" />
                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" 
                                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-border-width: 1;">
                            <content>
                                <VBox fx:id="contentComponentsContainer" spacing="15.0" style="-fx-background-color: transparent;">
                                    <padding>
                                        <Insets top="15.0" right="15.0" bottom="30.0" left="15.0"/>
                                    </padding>
                                </VBox>
                            </content>
                        </ScrollPane>
                    </VBox>
                </VBox>

                <!-- Tools Sidebar (Right) -->
                <VBox spacing="20.0" prefWidth="240.0" minWidth="240.0" 
                      style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 12; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
                    
                    <VBox spacing="8.0">
                        <Label text="TAMBAHKAN KOMPONEN" style="-fx-font-size: 11px; -fx-font-weight: 900; -fx-text-fill: #94a3b8;" />
                        <Button fx:id="addHeadingBtn" text="+ Heading" maxWidth="Infinity"
                                style="-fx-background-color: #059669; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
                        <Button fx:id="addParagrafBtn" text="+ Paragraf" maxWidth="Infinity"
                                style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
                        <Button fx:id="addListBtn" text="+ List" maxWidth="Infinity"
                                style="-fx-background-color: #34d399; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
                        <Button fx:id="addImageBtn" text="+ Gambar" maxWidth="Infinity"
                                style="-fx-background-color: #6ee7b7; -fx-text-fill: #064e3b; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 8; -fx-cursor: hand;" />
                    </VBox>

                    <Region VBox.vgrow="ALWAYS" />

                    <VBox spacing="10.0" style="-fx-background-color: #ecfdf5; -fx-padding: 15; -fx-background-radius: 8;">
                        <Label text="Petunjuk Editor" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #064e3b;" />
                        <Label text="• Preview sebelum simpan untuk melihat tampilan user." wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #065f46;" />
                        <Label text="• Gunakan panah untuk mengatur urutan komponen." wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #065f46;" />
                        <Label text="• Klik ikon sampah untuk menghapus komponen." wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #065f46;" />
                    </VBox>
                </VBox>
            </HBox>
        </VBox>
    </center>

</BorderPane>
