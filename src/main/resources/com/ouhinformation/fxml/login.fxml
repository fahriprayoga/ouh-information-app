<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="500.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ouhinformation.controllers.LoginController">

    <center>
        <StackPane BorderPane.alignment="CENTER">
            <VBox alignment="CENTER" maxWidth="-Infinity" maxHeight="-Infinity" prefWidth="380.0" spacing="25.0" style="-fx-background-color: -color-bg-default; -fx-background-radius: 12;" styleClass="elevated-2">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
                </padding>

                <VBox alignment="CENTER" spacing="5.0">
                    <Label styleClass="title-2" text="Welcome Back" />
                    <Label styleClass="text-muted" text="Masukkan username dan password untuk lanjut" />
                </VBox>

                <VBox spacing="15.0">

                    <VBox spacing="5.0">
                        <Label styleClass="text-muted" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="USERNAME" />
                        <TextField fx:id="usernameField" promptText="e.g. baratheon" />
                    </VBox>

                    <VBox spacing="5.0">
                        <Label styleClass="text-muted" style="-fx-font-size: 11px; -fx-font-weight: bold;" text="PASSWORD" />
                        <VBox>
                            <PasswordField fx:id="passwordField" promptText="enter your password" />
                            <TextField fx:id="visiblePasswordField" managed="false" promptText="enter your password" visible="false" />
                        </VBox>
                    </VBox>

                    <HBox alignment="CENTER_LEFT">
                        <CheckBox fx:id="showPasswordCheckBox" text="Show Password" />
                    </HBox>

                    <Button fx:id="loginButton" maxWidth="1.7976931348623157E308" styleClass="accent" text="LOG IN" />
                    
                    <Button fx:id="backButton" maxWidth="1.7976931348623157E308" text="Kembali ke Beranda" />

                    <Label fx:id="messageLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="danger" wrapText="true" />

                </VBox>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
