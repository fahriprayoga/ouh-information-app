<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.ouhinformation.controllers.HelloController"
            style="-fx-background-color: #f4f7f6;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="10.0" prefHeight="65.0"
              style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="10.0" right="25.0" bottom="10.0" left="25.0"/>
            </padding>
            <Label text="OUH Information" style="-fx-font-size: 22px; -fx-font-weight: 900; -fx-text-fill: #059669;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Login Akun" fx:id="loginButton" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 8 20 8 20; -fx-cursor: hand; -fx-font-weight: 700; -fx-background-radius: 6;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5.0" prefWidth="260.0" 
              style="-fx-background-color: #047857; -fx-border-color: #065f46; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets top="25.0" right="15.0" bottom="25.0" left="15.0"/>
            </padding>
            
            <Label text="LIHAT SELENGKAPNYA" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6ee7b7; -fx-padding: 0 0 10 10;" />
            
            <VBox fx:id="navbarVBox" spacing="5.0" />
        </VBox>
    </left>

    <center>
        <javafx.scene.control.ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent; -fx-padding: 0;">
            <VBox>
                <padding>
                    <Insets top="35.0" right="35.0" bottom="35.0" left="35.0"/>
                </padding>
                
                <VBox spacing="15.0" 
                      style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4); -fx-border-color: #f1f5f9; -fx-border-radius: 12; -fx-border-width: 1;">
                    <padding>
                        <Insets top="30.0" right="30.0" bottom="30.0" left="30.0"/>
                    </padding>
                    
                    <Label fx:id="contentTitle" text="Selamat Datang" style="-fx-font-size: 26px; -fx-font-weight: 800; -fx-text-fill: #0f172a;" wrapText="true" />
                    
                    <Label fx:id="contentDesc" wrapText="true" style="-fx-font-size: 15px; -fx-text-fill: #64748b; -fx-line-spacing: 6px;" 
                           text="Pilih menu di samping untuk melihat informasi lebih lanjut." />

                    <VBox fx:id="contentContainer" spacing="10.0" />

                    <VBox spacing="5.0" style="-fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0;">
                        <padding>
                            <Insets top="15.0" />
                        </padding>
                        <Label fx:id="contentCreated" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;" />
                        <Label fx:id="contentUpdated" style="-fx-font-size: 12px; -fx-text-fill: #94a3b8;" />
                    </VBox>
                </VBox>

                <!-- Comment Section -->
                <VBox spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 4); -fx-border-color: #f1f5f9; -fx-border-radius: 12; -fx-border-width: 1;">
                    <padding>
                        <Insets top="25.0" right="25.0" bottom="25.0" left="25.0"/>
                    </padding>
                    
                    <Label text="💬 Komentar" style="-fx-font-size: 18px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                    
                    <VBox spacing="10.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-border-width: 1;">
                        <Label text="Tinggalkan komentar Anda:" style="-fx-font-size: 13px; -fx-text-fill: #64748b; -fx-font-weight: bold;" />
                        <TextField fx:id="commentNameField" promptText="Nama Anda..." 
                                   style="-fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: white;" />
                        <TextArea fx:id="commentMessageField" promptText="Tulis komentar..." prefRowCount="3" wrapText="true"
                                  style="-fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-color: white;" />
                        <HBox alignment="CENTER_RIGHT">
                            <Button fx:id="submitCommentButton" text="Kirim Komentar" 
                                    style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 6; -fx-cursor: hand;" />
                        </HBox>
                    </VBox>
                    
                    <VBox fx:id="commentsListContainer" spacing="10.0" />
                </VBox>
            </VBox>
        </javafx.scene.control.ScrollPane>
    </center>

</BorderPane>
